# DigitalOcean SSH (provisioner)
DO_SSH_HOST=157.230.8.164
DO_SSH_USER=root
DO_SSH_PORT=22
DO_SSH_KEY_PATH=
DO_BACKEND_CONTAINER=frappe_docker-backend-1
DO_DB_ROOT_PASSWORD=

# Optional local docker target (env=local)
LOCAL_DB_ROOT_PASSWORD=

# Domain
SPACE_DOMAIN_SUFFIX=zatgo.online
SPACE_DROPLET_IP=157.230.8.164

# Control site APIs (erp.zatgo.online) — optional sync of Space Order
FRAPPE_BASE_URL=https://erp.zatgo.online
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
SPACE_INTERNAL_TOKEN=

# Provisioner env: cloud (default) or local
SPACE_BENCH_ENV=cloud

# Developer activity console (also on by default in `next dev`)
# NEXT_PUBLIC_ so the wizard shows the Dev console link
NEXT_PUBLIC_SPACE_DEV_CONSOLE=1
SPACE_DEV_CONSOLE=1
