# On the DigitalOcean droplet (space.zatgo.online), prefer local Docker:
SPACE_BENCH_ENV=local
LOCAL_BACKEND_CONTAINER=frappe_docker-backend-1
LOCAL_DB_ROOT_PASSWORD=

# Or SSH into the same / another host (dev laptop):
# SPACE_BENCH_ENV=cloud
DO_SSH_HOST=157.230.8.164
DO_SSH_USER=root
DO_SSH_PORT=22
DO_SSH_KEY_PATH=
DO_BACKEND_CONTAINER=frappe_docker-backend-1
DO_DB_ROOT_PASSWORD=

# Domain
SPACE_DOMAIN_SUFFIX=zatgo.online
SPACE_DROPLET_IP=157.230.8.164

# Soft pool (space-web control plane — data/control/store.json)
SPACE_RAM_POOL_MB=10240
SPACE_DISK_POOL_MB=102400

# Optional: dual-write Space Orders to a Frappe site (off by default)
# SPACE_FRAPPE_SYNC=1
# FRAPPE_BASE_URL=https://erp.zatgo.online
# FRAPPE_API_KEY=
# FRAPPE_API_SECRET=
# SPACE_INTERNAL_TOKEN=

# Developer activity console (off in production)
NEXT_PUBLIC_SPACE_DEV_CONSOLE=0
SPACE_DEV_CONSOLE=0
