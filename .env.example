# Space Frappe control plane (preferred)
SPACE_CONTROL_PLANE=frappe
FRAPPE_BASE_URL=https://space.zatgo.online
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
SPACE_INTERNAL_TOKEN=

# On the portal droplet host, local Docker for legacy fallback:
SPACE_BENCH_ENV=local
LOCAL_BACKEND_CONTAINER=frappe_docker-backend-1
LOCAL_DB_ROOT_PASSWORD=

# Domain
SPACE_DOMAIN_SUFFIX=zatgo.online
SPACE_DROPLET_IP=157.230.8.164

# Soft pool (legacy local store only)
SPACE_RAM_POOL_MB=10240
SPACE_DISK_POOL_MB=102400

# Developer activity console (off in production)
NEXT_PUBLIC_SPACE_DEV_CONSOLE=0
SPACE_DEV_CONSOLE=0
